        "formDescription": "={{ '<div style=\"background:#f0fdf4;border:1px solid #86efac;border-radius:10px;padding:16px 20px;margin-bottom:20px\"><strong style=\"color:#166534\">✅ Almost done! One final step.</strong><br/><span style=\"color:#15803d;font-size:13px\">Your registration details have been saved. Complete payment to confirm your seat.</span></div>' + '<div style=\"background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:24px;text-align:center;margin-bottom:20px\">' + '<p style=\"margin:0 0 4px;color:#64748b;font-size:13px\">Your selected track</p>' + '<h3 style=\"margin:0 0 6px;color:#1e293b;font-size:18px\">' + $json.trackName + '</h3>' + '<p style=\"font-size:32px;font-weight:800;color:#0ea5e9;margin:0 0 4px\">' + $json.price + '</p>' + '<p style=\"color:#94a3b8;font-size:12px;margin:0\">One-time payment · No recurring charges</p>' + '</div>' + '<div style=\"text-align:center;margin-bottom:20px\">' + '<p style=\"color:#475569;font-weight:600;font-size:14px;margin:0 0 14px\">📱 Scan the QR code to pay:</p>' + '<div style=\"background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:18px;display:inline-block\">' + '<img src=\"' + $json.qrImageUrl + '\" alt=\"Payment QR Code for ' + $json.trackName + '\" style=\"width:280px;height:280px;display:block;border-radius:8px\" />' + '</div>' + '<p style=\"color:#94a3b8;font-size:12px;margin:12px 0 0\">' + $json.bankNote + '</p>' + '</div>' + '<p style=\"color:#64748b;font-size:13px;margin:0\">⬇️ After paying, <strong>upload a screenshot</strong> of your payment receipt below. Our team will verify within 24 hours.</p>' }}",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Payment Screenshot",
              "fieldType": "file",
              "requiredField": true,
              "acceptFileTypes": ".jpg,.jpeg,.png,.pdf",
