    {
      "parameters": {
        "formTitle": "🎉 Registration Complete!",
        "formDescription": "={{ '<div style=\"background:#f0fdf4;border:1px solid #86efac;border-radius:12px;padding:24px;text-align:center;margin-bottom:20px\"><div style=\"font-size:56px;margin-bottom:10px\">🎉</div><h2 style=\"color:#166534;margin:0 0 8px\">Thank You, ' + $('Form — Page 2: Personal Info').item.json['First Name (English)'] + '!</h2><p style=\"color:#15803d;margin:0;font-size:14px\">Your registration is received. We'll verify your payment within <strong>24 hours</strong>.</p></div><div style=\"background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:20px;margin-bottom:16px\"><h3 style=\"color:#1e293b;margin:0 0 14px;font-size:15px\">📋 Summary</h3><table style=\"width:100%;font-size:14px\"><tr style=\"border-bottom:1px solid #f1f5f9\"><td style=\"padding:9px 0;color:#64748b\">Track</td><td style=\"padding:9px 0;font-weight:600;color:#1e293b\">' + $json.trackLabel + '</td></tr><tr style=\"border-bottom:1px solid #f1f5f9\"><td style=\"padding:9px 0;color:#64748b\">Start Date</td><td style=\"padding:9px 0;font-weight:600;color:#166534\">' + $json.classStartDate + '</td></tr><tr><td style=\"padding:9px 0;color:#64748b\">Schedule</td><td style=\"padding:9px 0;color:#1e293b\">' + $json.schedule + '</td></tr></table></div><div style=\"background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:20px;margin-bottom:16px\"><h3 style=\"color:#1e40af;margin:0 0 10px;font-size:15px\">📱 Join Telegram Community</h3><p style=\"color:#3b5a9a;margin:0 0 14px;font-size:13px\">Once your payment is verified, join our community group:</p><a href=\"' + $json.telegramGroupLink + '\" target=\"_blank\" style=\"display:inline-block;padding:12px 28px;background:#0088cc;color:#fff;border-radius:8px;text-decoration:none;font-weight:700\">Join Group →</a></div><div style=\"background:#fef9e7;border:1px solid #fcd34d;border-radius:8px;padding:14px 16px\"><p style=\"color:#92400e;margin:0;font-size:13px\">⏳ <strong>Next steps:</strong> Our admin will verify your payment and send you a confirmation message on Telegram. Check your email <strong>' + $('Form — Page 2: Personal Info').item.json['Email Address'] + '</strong> for updates.</p></div>' }}",
        "formFields": { "values": [] },
